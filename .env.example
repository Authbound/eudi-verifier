# Production example for the Kotlin EUDI verifier
# (do not use real secrets in this file)

SPRING_PROFILES_ACTIVE=prod
SPRING_DATA_REDIS_URL=redis://redis:6379

# Verifier public URL (used in request_uri and response_uri)
VERIFIER_PUBLICURL=https://verifier.example.com

# S2S auth (Gateway -> verifier)
EUDI_S2S_JWKS_URL=https://gateway.example.com/.well-known/eudi-s2s-jwks.json
EUDI_S2S_ISSUER=https://gateway.example.com
EUDI_S2S_AUDIENCE=eudi-verifier
EUDI_S2S_ISSUERS=
EUDI_S2S_AUDIENCES=
EUDI_S2S_CLOCK_SKEW_SECONDS=60

# Trust sources baked into the verifier artifact
VERIFIER_TRUSTSOURCES_0_PATTERN=urn:vc:authbound:.*
VERIFIER_TRUSTSOURCES_0_KEYSTORE_PATH=classpath:authbound-root-trust.jks
VERIFIER_TRUSTSOURCES_0_KEYSTORE_TYPE=JKS
VERIFIER_TRUSTSOURCES_0_KEYSTORE_PASSWORD=changeit
VERIFIER_TRUSTSOURCES_1_PATTERN=.*
VERIFIER_TRUSTSOURCES_1_LOTL_LOCATION=https://ec.europa.eu/tools/lotl/eu-lotl.xml
VERIFIER_TRUSTSOURCES_1_LOTL_REFRESHINTERVAL=0 0 * * * *
VERIFIER_TRUSTSOURCES_1_LOTL_KEYSTORE_PATH=classpath:eu-lotl-signers.jks
VERIFIER_TRUSTSOURCES_1_LOTL_KEYSTORE_TYPE=JKS
VERIFIER_TRUSTSOURCES_1_LOTL_KEYSTORE_PASSWORD=changeit

# JAR signing (KMS)
VERIFIER_JAR_SIGNING_KEY=AwsKms
VERIFIER_JAR_SIGNING_KEY_KMS_KEY_ID=arn:aws:kms:eu-west-1:000000000000:key/00000000-0000-0000-0000-000000000000
VERIFIER_JAR_SIGNING_KEY_KMS_REGION=eu-west-1
VERIFIER_JAR_SIGNING_KEY_KMS_KID=

# CORS (required in prod)
CORS_ORIGINS=https://app.example.com
CORS_METHODS=GET,POST,OPTIONS
CORS_HEADERS=Authorization,Content-Type
CORS_CREDENTIALS=false
CORS_MAXAGE=3600
